<bblocks://ogc.geo.topo.features.topo-feature-multi-collection> a skos:Concept,
        dcat:Dataset,
        bblocks:BBlock,
        bblocks:Schema ;
    rdfs:label "Topo Feature Multi-Collection" ;
    dct:abstract "A schema for a structured topology dataset containing typed Feature Collections for each topological dimension: points, edges (Line features), faces (Face features), and solids (Polyhedron features). Each collection is restricted to its specific building block type, enabling referential integrity across the topology hierarchy."^^<https://www.w3.org/ns/iana/media-types/text/markdown> ;
    dct:created "2024-01-01T00:00:00+00:00"^^xsd:dateTime ;
    dct:description [ dct:format "text/markdown" ;
            rdfs:isDefinedBy <https://surroundaustralia.github.io/topo-feature/build/generateddocs/markdown/geo/topo/features/topo-feature-multi-collection/index.md> ],
        [ dct:format "text/html" ;
            rdfs:isDefinedBy <https://surroundaustralia.github.io/topo-feature/bblock/ogc.geo.topo.features.topo-feature-multi-collection> ],
        [ dct:format "application/json" ;
            rdfs:isDefinedBy <https://surroundaustralia.github.io/topo-feature/build/generateddocs/json-full/geo/topo/features/topo-feature-multi-collection/index.json> ] ;
    dct:hasVersion "0.1" ;
    dct:modified "2026-04-16"^^xsd:date ;
    skos:inScheme <https://surroundaustralia.github.io/topo-feature/> ;
    skos:prefLabel "Topo Feature Multi-Collection" ;
    skos:topConceptOf <https://surroundaustralia.github.io/topo-feature/> ;
    dcat:keyword "3D",
        "collection",
        "feature",
        "topology" ;
    prof:hasResource [ dct:conformsTo <https://json-schema.org/draft/2020-12/schema> ;
            dct:format "application/json" ;
