{
  "@context": {
    "geojson": "https://purl.org/geojson/vocab#",
    "topo": "https://purl.org/geojson/topo#",
    "topology": {
      "@type": "@id",
      "@id": "geojson:topology"
    },
    "references": {
      "@id": "geojson:relatedFeatures",
      "@type": "@id",
      "@container": "@list"
    },
    "directed_references": {
      "@id": "topo:directedReferences",
      "@container": "@list"
    },
    "ref": {
      "@id": "@id"
    },
    "orientation": "topo:orientation",
    "Face": "topo:Face",
    "Ring": "topo:Ring",
    "Shell": "topo:Shell",
    "Solid": "topo:Solid",
    "rings": { "@id": "topo:rings", "@container": "@list" },
    "shells": { "@id": "topo:shells", "@container": "@list" }
  }
}
