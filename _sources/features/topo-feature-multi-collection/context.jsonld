{
  "@context": {
    "geojson": "https://purl.org/geojson/vocab#",
    "topo": "https://purl.org/geojson/topo#",
    "Face": "topo:Face",
    "Ring": "topo:Ring",
    "Shell": "topo:Shell",
    "Solid": "topo:Solid",
    "points": {
      "@id": "topo:points",
      "@container": "@list"
    },
    "edges": {
      "@id": "topo:edges",
      "@container": "@list"
    },
    "faces": {
      "@id": "topo:faces",
      "@container": "@list"
    },
    "rings": {
      "@id": "topo:rings",
      "@container": "@list"
    },
    "shells": {
      "@id": "topo:shells",
      "@container": "@list"
    },
    "solids": {
      "@id": "topo:shells",
      "@container": "@list"
    }
  }
}
