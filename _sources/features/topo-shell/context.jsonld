{
  "@context": {
    "geojson": "https://purl.org/geojson/vocab#",
    "topo": "https://purl.org/geojson/topo#",
    "topology": {
      "@type": "@id",
      "@id": "geojson:topology"
    },
    "Shell": "topo:Shell",
    "directed_references": {
      "@id": "topo:directedReferences",
      "@container": "@list"
    },
    "ref": {
      "@id": "@id"
    },
    "orientation": "topo:orientation"
  }
}
